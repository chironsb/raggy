# RAG Configuration - Everything runs locally!

# Server Configuration
PORT=3001
HOST=localhost
CORS_ORIGIN=http://localhost:3000

# RAG Settings
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_MAX_RESULTS=5
RAG_SIMILARITY_THRESHOLD=0.35

# Hybrid search: vector (LanceDB ANN) + lexical (MiniSearch) fused with RRF
# Set RAG_HYBRID_SEARCH=0 to disable (vector-only)
RAG_HYBRID_SEARCH=1
# Allow strong keyword matches even if vector score is below threshold
RAG_HYBRID_RELAX=1
RAG_HYBRID_VECTOR_POOL=48
RAG_HYBRID_LEXICAL_POOL=48
RAG_RRF_K=60
RAG_VECTOR_INDEX_MIN_ROWS=64

# Local storage (current stack: LanceDB + lexical indexes + document files)
# VECTOR_DB_PATH: unused for new installs; only old pre-LanceDB JSON lived under data/vectors/
VECTOR_DB_PATH=./data/vectors
LANCE_DB_PATH=./data/lancedb
LEXICAL_INDEX_PATH=./data/lexical
DOCUMENTS_PATH=./data/documents
CACHE_PATH=./data/cache

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/raggy.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Performance Settings
MAX_WORKERS=4
CACHE_TTL=3600000
EMBEDDING_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2

# Security (optional)
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_FILE_SIZE_MB=50